#!/bin/bash
# html/*.html (nginx 문서허브 원본)이 커밋에 포함되면
# 같은 이름으로 이미 존재하는 docs-hub/public/html/*.html (GitHub Pages 배포 소스)에 자동 복사한다.
# 새 파일을 만들지는 않는다 — 이미 양쪽에 존재하는 파일만 동기화 대상.
set -e
cd "$(git rev-parse --show-toplevel)"

staged_files=$(git diff --cached --name-only --diff-filter=ACM -- 'html/*.html')
[ -z "$staged_files" ] && exit 0

while IFS= read -r file; do
  [ -z "$file" ] && continue
  base="$(basename "$file")"
  target="docs-hub/public/html/$base"
  if [ -f "$target" ] && ! cmp -s "$file" "$target"; then
    cp "$file" "$target"
    git add "$target"
    echo "[pre-commit sync] $file -> $target"
  fi
done <<< "$staged_files"

exit 0
